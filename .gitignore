# Large CARLA release builds downloaded by scripts/install_ub_carla.sh
/CARLA/Builds/

# Previous release download location used during installer development
/scripts/Releases/

# Temporary release archives if a download is saved inside the repo
/CARLA/*.zip
/CARLA/*.zip.*
/scripts/*.zip
/scripts/*.zip.*

# Keep Autoware data mount points in the repo, but do not track their contents.
/Autoware/host_data/*
!/Autoware/host_data/.gitkeep
/Autoware/autoware_data/*
!/Autoware/autoware_data/.gitkeep
